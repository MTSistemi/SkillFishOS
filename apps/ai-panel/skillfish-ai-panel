#!/usr/bin/env python3
# SkillFish AI — KDE-native panel (PyQt6/Qt Widgets) to start/stop the local LLM
# engine (Ollama + Vulkan). Auto-themed by Kvantum/Breeze.
# The skillfish user is in the docker group => docker commands run without root.
# Bilingual UI (IT/EN), auto-detected from the LANG/LC_* environment.
import sys, os, subprocess
from PyQt6.QtCore import Qt, QTimer, QThread, pyqtSignal
from PyQt6.QtGui import QIcon, QPixmap
from PyQt6.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
                             QLabel, QGroupBox, QCheckBox, QPushButton)

STACK_DIR = "/opt/stacks/skillfish-ai"
CONTAINER = "skillfish-ollama"
MODEL     = "qwen3:14b"          # the chat model (the others were pruned)
DOCKGE_URL= "http://localhost:5001"
WEBUI_URL = "http://localhost:8080"
ICON      = "/usr/share/icons/hicolor/256x256/apps/skillfish-ai.png"


# ---------- i18n ----------
def _detect_lang():
    # Standard locale precedence: LC_ALL overrides LC_MESSAGES overrides LANG.
    # LANGUAGE (gettext colon-list) is the last fallback. First non-empty wins.
    val = (os.environ.get("LC_ALL") or os.environ.get("LC_MESSAGES")
           or os.environ.get("LANG") or os.environ.get("LANGUAGE") or "")
    return "it" if val.lower().startswith("it") else "en"

LANG = _detect_lang()

def L(it, en):
    """Return the IT or EN string depending on the detected locale."""
    return it if LANG == "it" else en


def sh(cmd, t=60):
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=t)
        return r.returncode, (r.stdout or "").strip(), (r.stderr or "").strip()
    except Exception as e:
        return 1, "", str(e)


class Toggler(QThread):
    """Starts/stops the docker stack in a thread (keeps the UI responsive)."""
    done = pyqtSignal(bool)
    def __init__(self, state):
        super().__init__(); self.state = state
    def run(self):
        if self.state:
            sh(f"cd {STACK_DIR} && docker compose up -d", 120)
        else:
            sh(f"cd {STACK_DIR} && docker compose stop", 120)
        self.done.emit(self.state)


class Panel(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("SkillFish AI")
        self.setWindowIcon(QIcon(ICON))
        self.resize(580, 440)
        self.busy = False
        self._t = None

        w = QWidget(); self.setCentralWidget(w)
        v = QVBoxLayout(w); v.setContentsMargins(22, 18, 22, 18); v.setSpacing(14)

        # --- header with fish + title ---
        h = QHBoxLayout()
        img = QLabel(); pm = QPixmap(ICON)
        if not pm.isNull():
            img.setPixmap(pm.scaled(40, 40, Qt.AspectRatioMode.KeepAspectRatio,
                                    Qt.TransformationMode.SmoothTransformation))
        h.addWidget(img)
        tcol = QVBoxLayout(); tcol.setSpacing(0)
        title = QLabel("SkillFish AI"); title.setStyleSheet("font-size:20px;font-weight:800;color:#e8c878;")
        sub = QLabel(L("Motore LLM locale — Qwen3 14B su GPU (Vulkan)",
                       "Local LLM engine — Qwen3 14B on GPU (Vulkan)"))
        sub.setStyleSheet("color:#b9a07a;")
        tcol.addWidget(title); tcol.addWidget(sub)
        h.addLayout(tcol); h.addStretch(1)
        v.addLayout(h)

        # --- main switch ---
        g = QGroupBox(L("Motore AI (LLM)", "AI Engine (LLM)"))
        gv = QVBoxLayout(g)
        self.cb = QCheckBox(L("Acceso  —  accende/spegne Ollama. Spegnilo prima di giocare.",
                              "On  —  starts/stops Ollama. Turn it off before gaming."))
        self.cb.toggled.connect(self.on_toggle)
        gv.addWidget(self.cb)
        v.addWidget(g)

        # --- status ---
        self.status = QLabel("…"); self.status.setWordWrap(True)
        v.addWidget(self.status)

        # --- gaming warning ---
        warn = QLabel(L("⚠️  AI e giochi/Android non possono girare insieme: usano la stessa "
                        "GPU e memoria. Spegni il motore AI prima di giocare.",
                        "⚠️  AI and games/Android can't run together: they share the same "
                        "GPU and memory. Turn the AI engine off before gaming."))
        warn.setWordWrap(True); warn.setStyleSheet("color:#b9a07a;")
        v.addWidget(warn)
        v.addStretch(1)

        # --- buttons ---
        b = QHBoxLayout()
        bw = QPushButton(L("Apri Chat AI (web)", "Open AI Chat (web)")); bw.clicked.connect(lambda: sh(f"xdg-open {WEBUI_URL} &"))
        bd = QPushButton(L("Apri Dockge", "Open Dockge"));               bd.clicked.connect(lambda: sh(f"xdg-open {DOCKGE_URL} &"))
        bt = QPushButton(L("Chat in terminale (OpenCode)", "Terminal chat (OpenCode)")); bt.clicked.connect(self.opencode)
        br = QPushButton(L("Aggiorna", "Refresh"));                      br.clicked.connect(self.refresh)
        for x in (bw, bd, bt, br):
            b.addWidget(x)
        v.addLayout(b)

        self.statusBar()
        self.refresh()
        self.timer = QTimer(self); self.timer.timeout.connect(self._tick); self.timer.start(5000)

    def _tick(self):
        if not self.busy:
            self.refresh()

    def is_running(self):
        _, out, _ = sh(f"docker inspect -f '{{{{.State.Running}}}}' {CONTAINER}", 10)
        return out == "true"

    def model_loaded(self):
        _, out, _ = sh(f"docker exec {CONTAINER} ollama ps", 10)
        return MODEL.split(':')[0] in out

    def refresh(self):
        run = self.is_running()
        self.cb.blockSignals(True); self.cb.setChecked(run); self.cb.blockSignals(False)
        if run:
            loaded = self.model_loaded()
            t = (L("● Motore ACCESO — modello in VRAM (pronto)",
                   "● Engine ON — model in VRAM (ready)") if loaded
                 else L("● Motore ACCESO — pronto (il modello si carica alla 1ª richiesta)",
                        "● Engine ON — ready (model loads on the 1st request)"))
            self.status.setText(t + L(f"\nAPI: http://localhost:11434   ·   modello: {MODEL}",
                                      f"\nAPI: http://localhost:11434   ·   model: {MODEL}"))
            self.status.setStyleSheet("color:#9ccf6a;font-weight:600;")
        else:
            self.status.setText(L("○ Motore SPENTO — GPU/memoria libere per giochi e Android",
                                  "○ Engine OFF — GPU/memory free for games and Android"))
            self.status.setStyleSheet("color:#cf8a6a;font-weight:600;")

    def on_toggle(self, state):
        if self.busy:
            return
        self.busy = True
        self.cb.setEnabled(False)
        self.status.setText(L("… operazione in corso …", "… working …"))
        self.status.setStyleSheet("color:#d8a849;font-weight:600;")
        self._t = Toggler(state); self._t.done.connect(self._done); self._t.start()

    def _done(self, state):
        self.busy = False
        self.cb.setEnabled(True)
        self.refresh()
        self.statusBar().showMessage(L("Motore AI acceso", "AI engine on") if state
                                     else L("Motore AI spento", "AI engine off"), 2500)

    def opencode(self):
        sh("setsid alacritty -e opencode >/dev/null 2>&1 &")
        self.statusBar().showMessage(L("Apro OpenCode nel terminale", "Opening OpenCode in terminal"), 2500)


def main():
    app = QApplication(sys.argv)
    app.setApplicationName("SkillFish AI")
    app.setDesktopFileName("os.skillfish.ai")   # binds window to the .desktop (correct icon)
    app.setWindowIcon(QIcon(ICON))
    p = Panel(); p.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
