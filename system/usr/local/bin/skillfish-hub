#!/usr/bin/env python3
# SkillFishOS Hub — a Discover-style software centre for APT, Flatpak and Snap.
# Categories, search, app pages with screenshots, installed list, full system
# updates, and repository/source management. KDE-native PyQt6, brass themed.
import sys, os, re, json, subprocess, html
from PyQt6.QtCore import Qt, QThread, pyqtSignal, QSize, QTimer
from PyQt6.QtGui import QIcon, QPixmap, QFont, QPainter, QColor
from PyQt6.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
                             QGridLayout, QLabel, QPushButton, QLineEdit, QScrollArea,
                             QStackedWidget, QFrame, QToolButton, QButtonGroup, QMessageBox,
                             QDialog, QFormLayout, QComboBox, QCheckBox, QPlainTextEdit,
                             QSizePolicy, QProgressBar)

ICON = "/usr/share/icons/hicolor/256x256/apps/skillfishos.png"
HELPER = "/usr/local/bin/skillfish-hub-helper"
AETHERIUM = "aetherium"   # our repo origin

def _lang():
    v = (os.environ.get("LC_ALL") or os.environ.get("LC_MESSAGES")
         or os.environ.get("LANG") or os.environ.get("LANGUAGE") or "")
    return "it" if v.lower().startswith("it") else "en"
LANG = _lang()
def L(it, en): return it if LANG == "it" else en

def run(cmd, t=120):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=t)
        return r.returncode, (r.stdout or ""), (r.stderr or "")
    except Exception as e:
        return 1, "", str(e)

def have(binname):
    from shutil import which
    return which(binname) is not None

# ---- Discover-style top categories -> freedesktop category members ----
CATEGORIES = [
    ("Game",         L("Giochi", "Games"),          "🎮", {"Game"}),
    ("Development",  L("Sviluppo", "Development"),   "🛠️", {"Development"}),
    ("Graphics",     L("Grafica", "Graphics"),       "🎨", {"Graphics"}),
    ("AudioVideo",   L("Multimedia", "Multimedia"),  "🎬", {"AudioVideo", "Audio", "Video"}),
    ("Network",      L("Internet", "Internet"),      "🌐", {"Network"}),
    ("Office",       L("Produttività", "Productivity"), "📝", {"Office"}),
    ("Education",    L("Istruzione e scienza", "Education & science"), "📚", {"Education", "Science"}),
    ("System",       L("Sistema", "System"),         "⚙️", {"System", "Settings"}),
    ("Utility",      L("Utilità", "Utilities"),      "🧰", {"Utility", "Accessibility"}),
]
def top_category_of(cats):
    s = set(cats or [])
    for key, _name, _emoji, members in CATEGORIES:
        if s & members:
            return key
    return "Utility"


class App:
    __slots__ = ("backend", "appid", "pkgid", "name", "summary", "description",
                 "icon", "screens", "cats", "installed", "ver", "ver_inst", "origin")
    def __init__(self, backend, appid, pkgid, name, summary="", description="",
                 icon=None, screens=None, cats=None, installed=False, ver="", ver_inst="", origin=""):
        self.backend = backend; self.appid = appid; self.pkgid = pkgid
        self.name = name; self.summary = summary; self.description = description
        self.icon = icon; self.screens = screens or []; self.cats = cats or []
        self.installed = installed; self.ver = ver; self.ver_inst = ver_inst; self.origin = origin
    @property
    def key(self):
        return "%s:%s" % (self.backend, self.appid)


# ============================ BACKENDS / CATALOG ============================
class Catalog:
    """Builds the unified app catalog from AppStream (APT) + flatpak + snap."""
    def __init__(self):
        self.apps = {}          # key -> App
        self.by_cat = {}        # top-category-key -> [App]

    # ---- APT via AppStream ----
    def load_apt(self, progress=None):
        try:
            import gi; gi.require_version("AppStream", "1.0")
            from gi.repository import AppStream as AS
        except Exception:
            return
        try:
            import apt
            cache = apt.Cache()
        except Exception:
            cache = None
        pool = AS.Pool()
        try:
            pool.load()
        except Exception:
            pass
        comps = pool.get_components()
        arr = comps.as_array() if hasattr(comps, "as_array") else list(comps)
        for c in arr:
            try:
                if c.get_kind() != AS.ComponentKind.DESKTOP_APP:
                    continue
                pkg = c.get_pkgname()
                if not pkg:
                    continue
                inst = False; ver = ""; ver_inst = ""; origin = ""
                if cache is not None and pkg in cache:
                    p = cache[pkg]
                    inst = p.is_installed
                    if p.candidate:
                        ver = p.candidate.version
                        origin = next((o.archive for o in p.candidate.origins if o.archive), "")
                    if p.installed: ver_inst = p.installed.version
                elif cache is not None:
                    continue  # not available in apt -> skip
                ic = c.get_icon_by_size(64, 64)
                icon = None
                if ic and hasattr(ic, "get_url") and ic.get_url():
                    u = ic.get_url()
                    icon = u[7:] if u.startswith("file://") else u
                cats = list(c.get_categories() or [])
                a = App("apt", c.get_id(), pkg, c.get_name() or pkg, c.get_summary() or "",
                        c.get_description() or "", icon, self._as_screens(c), cats, inst, ver, ver_inst, origin)
                self.apps[a.key] = a
            except Exception:
                continue  # best-effort: skip malformed components
        # Include our own SkillFishOS (aetherium) packages even if they ship no
        # AppStream metainfo, so they appear in "Featured".
        if cache is not None:
            import glob as _glob
            have_pkgids = {a.pkgid for a in self.apps.values() if a.backend == "apt"}
            for pf in _glob.glob("/var/lib/apt/lists/*aetherium*Packages"):
                try:
                    with open(pf, errors="replace") as f:
                        for line in f:
                            if not line.startswith("Package: "):
                                continue
                            name = line[9:].strip()
                            if name in have_pkgids or name not in cache:
                                continue
                            p = cache[name]; cand = p.candidate
                            a = App("apt", "skf:" + name, name, name,
                                    summary=(cand.summary if cand else "") or "",
                                    description=(cand.description if cand else "") or "",
                                    icon=None, screens=[], cats=[],
                                    installed=p.is_installed,
                                    ver=cand.version if cand else "",
                                    ver_inst=p.installed.version if p.installed else "",
                                    origin="aetherium")
                            self.apps[a.key] = a; have_pkgids.add(name)
                except Exception:
                    pass  # best-effort: skip unreadable Packages file
        self._reindex()

    def _as_screens(self, c):
        out = []
        try:
            scr = c.get_screenshots_all()
            sa = scr.as_array() if hasattr(scr, "as_array") else list(scr)
            for s in sa:
                imgs = s.get_images()
                ia = imgs.as_array() if hasattr(imgs, "as_array") else list(imgs)
                best = None; bw = 0
                for im in ia:
                    w = im.get_width() or 0
                    if w >= bw:
                        bw = w; best = im.get_url()
                if best:
                    out.append(best[7:] if best.startswith("file://") else best)
        except Exception:
            pass  # best-effort: screenshots are optional
        return out[:6]

    # ---- flatpak ----
    def load_flatpak_installed(self):
        if not have("flatpak"):
            return
        rc, out, _ = run(["flatpak", "list", "--app", "--columns=application,name,version,origin"], 30)
        for ln in out.splitlines():
            f = ln.split("\t")
            if len(f) < 2: continue
            ref = f[0].strip()
            a = App("flatpak", ref, ref, f[1].strip() or ref, "",
                    "", None, [], True, "", f[2].strip() if len(f) > 2 else "",
                    f[3].strip() if len(f) > 3 else "flathub")
            self.apps[a.key] = a

    # ---- snap ----
    def load_snap_installed(self):
        if not have("snap"):
            return
        rc, out, _ = run(["snap", "list"], 30)
        for ln in out.splitlines()[1:]:
            f = ln.split()
            if not f: continue
            name = f[0]
            a = App("snap", name, name, name, "", "", None, [], True,
                    "", f[1] if len(f) > 1 else "", "snap")
            self.apps[a.key] = a

    def _reindex(self):
        self.by_cat = {}
        for a in self.apps.values():
            if a.backend != "apt":
                continue
            k = top_category_of(a.cats)
            self.by_cat.setdefault(k, []).append(a)
        for k in self.by_cat:
            self.by_cat[k].sort(key=lambda a: a.name.lower())

    # ---- live search across backends ----
    def search(self, q):
        ql = q.lower().strip()
        res = []
        for a in self.apps.values():
            if a.backend == "apt" and (ql in a.name.lower() or ql in (a.summary or "").lower() or ql in a.pkgid.lower()):
                res.append(a)
        res.sort(key=lambda a: (not a.installed, a.name.lower()))
        # flatpak live
        if have("flatpak"):
            rc, out, _ = run(["flatpak", "search", "--columns=application,name,description,version", q], 25)
            for ln in out.splitlines():
                f = ln.split("\t")
                if len(f) < 2 or f[0] == "Application ID": continue
                ref = f[0].strip()
                key = "flatpak:" + ref
                if key in self.apps:
                    res.append(self.apps[key]); continue
                res.append(App("flatpak", ref, ref, f[1].strip(),
                               f[2].strip() if len(f) > 2 else "", "", None, [], False,
                               f[3].strip() if len(f) > 3 else "", "", "flathub"))
        # snap live
        if have("snap"):
            rc, out, _ = run(["snap", "find", q], 25)
            for ln in out.splitlines()[1:]:
                f = ln.split(None, 4)
                if len(f) < 1: continue
                name = f[0]
                key = "snap:" + name
                if key in self.apps:
                    res.append(self.apps[key]); continue
                res.append(App("snap", name, name, name,
                               f[4] if len(f) > 4 else "", "", None, [], False,
                               f[1] if len(f) > 1 else "", "", "snap"))
        # de-dup keep order
        seen = set(); uniq = []
        for a in res:
            if a.key in seen: continue
            seen.add(a.key); uniq.append(a)
        return uniq

    def updates(self):
        ups = []
        # apt
        if have("apt-get"):
            rc, out, _ = run(["apt-get", "-s", "full-upgrade"], 60)
            for ln in out.splitlines():
                m = re.match(r'Inst (\S+) \[([^\]]*)\] \(([^ ]+)', ln)
                if m:
                    ups.append(("apt", m.group(1), m.group(2), m.group(3)))
        # flatpak
        if have("flatpak"):
            rc, out, _ = run(["flatpak", "remote-ls", "--updates", "--columns=application,version"], 40)
            for ln in out.splitlines():
                f = ln.split("\t")
                if len(f) >= 1 and f[0] and f[0] != "Application ID":
                    ups.append(("flatpak", f[0], "", f[1] if len(f) > 1 else ""))
        # snap
        if have("snap"):
            rc, out, _ = run(["snap", "refresh", "--list"], 40)
            for ln in out.splitlines()[1:]:
                f = ln.split()
                if f:
                    ups.append(("snap", f[0], "", f[1] if len(f) > 1 else ""))
        return ups


# ============================ THREADS ============================
class Loader(QThread):
    done = pyqtSignal(object)
    msg = pyqtSignal(str)
    def run(self):
        cat = Catalog()
        self.msg.emit(L("Carico il catalogo APT (AppStream)…", "Loading the APT catalogue (AppStream)…"))
        cat.load_apt()
        self.msg.emit(L("Leggo Flatpak e Snap…", "Reading Flatpak and Snap…"))
        cat.load_flatpak_installed()
        cat.load_snap_installed()
        self.done.emit(cat)


class Op(QThread):
    line = pyqtSignal(str)
    done = pyqtSignal(int)
    def __init__(self, argv, t=3600):
        super().__init__(); self.argv = argv; self.t = t
    def run(self):
        try:
            p = subprocess.Popen(self.argv, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                                 text=True, bufsize=1)
            for ln in iter(p.stdout.readline, ""):
                if ln: self.line.emit(ln.rstrip())
            p.wait(self.t); self.done.emit(p.returncode)
        except Exception as e:
            self.line.emit(str(e)); self.done.emit(1)


class UpdatesThread(QThread):
    done = pyqtSignal(object)
    def __init__(self, cat): super().__init__(); self.cat = cat
    def run(self): self.done.emit(self.cat.updates())


class SearchThread(QThread):
    done = pyqtSignal(object)
    def __init__(self, cat, q): super().__init__(); self.cat = cat; self.q = q
    def run(self): self.done.emit(self.cat.search(self.q))


# ============================ WIDGETS ============================
def badge(text, color="#b9a07a"):
    l = QLabel(text); l.setStyleSheet(
        "background:rgba(216,168,73,0.14);color:%s;border-radius:7px;padding:1px 7px;font-size:11px;" % color)
    l.setMaximumHeight(20)
    return l

def pixmap_for(app, size=48):
    if app.icon and os.path.exists(app.icon):
        pm = QPixmap(app.icon)
        if not pm.isNull():
            return pm.scaled(size, size, Qt.AspectRatioMode.KeepAspectRatio, Qt.TransformationMode.SmoothTransformation)
    # fallback: themed icon or generic
    ic = QIcon.fromTheme({"flatpak": "flatpak", "snap": "snap-store"}.get(app.backend, "application-x-executable"))
    if not ic.isNull():
        return ic.pixmap(size, size)
    pm = QPixmap(ICON)
    return pm.scaled(size, size, Qt.AspectRatioMode.KeepAspectRatio, Qt.TransformationMode.SmoothTransformation) if not pm.isNull() else QPixmap()

SRC_LABEL = {"apt": "APT", "flatpak": "Flatpak", "snap": "Snap"}

class AppCard(QFrame):
    def __init__(self, app, on_open):
        super().__init__()
        self.setFixedHeight(82); self.setCursor(Qt.CursorShape.PointingHandCursor)
        self.setStyleSheet("QFrame{background:rgba(255,255,255,0.03);border:1px solid rgba(216,168,73,0.18);border-radius:12px;}"
                           "QFrame:hover{background:rgba(216,168,73,0.08);}")
        self.app = app; self.on_open = on_open
        h = QHBoxLayout(self); h.setContentsMargins(12, 8, 12, 8); h.setSpacing(12)
        ic = QLabel(); ic.setPixmap(pixmap_for(app, 48)); ic.setFixedWidth(52); h.addWidget(ic)
        col = QVBoxLayout(); col.setSpacing(1)
        top = QHBoxLayout(); top.setSpacing(8)
        nm = QLabel(app.name); nm.setStyleSheet("font-weight:700;color:#f1e3c6;font-size:14px;")
        top.addWidget(nm)
        src = SRC_LABEL.get(app.backend, app.backend)
        if app.backend == "apt" and app.origin == AETHERIUM: src = "SkillFishOS"
        top.addWidget(badge(src));
        if app.installed: top.addWidget(badge("✓ " + L("installato", "installed"), "#9ccf6a"))
        top.addStretch(1)
        col.addLayout(top)
        sm = QLabel((app.summary or "").strip()); sm.setStyleSheet("color:#b9a07a;font-size:12px;")
        sm.setWordWrap(False); col.addWidget(sm)
        h.addLayout(col, 1)
        self._lay = h
    def mouseReleaseEvent(self, e):
        if e.button() == Qt.MouseButton.LeftButton:
            self.on_open(self.app)


# ============================ MAIN WINDOW ============================
class Hub(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle(L("SkillFishOS Hub — Software", "SkillFishOS Hub — Software"))
        self.setWindowIcon(QIcon(ICON))
        self.resize(1040, 720)
        self.cat = None
        self._op = None

        root = QWidget(); self.setCentralWidget(root)
        outer = QHBoxLayout(root); outer.setContentsMargins(0, 0, 0, 0); outer.setSpacing(0)

        # ---- sidebar ----
        side = QFrame(); side.setFixedWidth(196)
        side.setStyleSheet("QFrame{background:#0f0c07;border-right:1px solid rgba(216,168,73,0.18);}")
        sv = QVBoxLayout(side); sv.setContentsMargins(10, 16, 10, 16); sv.setSpacing(4)
        logo = QHBoxLayout(); lpm = QLabel(); pm = QPixmap(ICON)
        if not pm.isNull(): lpm.setPixmap(pm.scaled(28, 28, Qt.AspectRatioMode.KeepAspectRatio, Qt.TransformationMode.SmoothTransformation))
        logo.addWidget(lpm); lt = QLabel("Hub"); lt.setStyleSheet("font-size:18px;font-weight:800;color:#e8c878;")
        logo.addWidget(lt); logo.addStretch(1); sv.addLayout(logo); sv.addSpacing(10)
        self.navgrp = QButtonGroup(self)
        self.nav = {}
        for key, label, emoji in [("home", L("Esplora", "Explore"), "✦"),
                                  ("cats", L("Categorie", "Categories"), "▤"),
                                  ("installed", L("Installati", "Installed"), "✓"),
                                  ("updates", L("Aggiornamenti", "Updates"), "⟳"),
                                  ("sources", L("Sorgenti", "Sources"), "⚙")]:
            b = QToolButton(); b.setText("  %s   %s" % (emoji, label)); b.setCheckable(True)
            b.setToolButtonStyle(Qt.ToolButtonStyle.ToolButtonTextOnly)
            b.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Fixed)
            b.setStyleSheet("QToolButton{color:#cdbb95;text-align:left;padding:9px 10px;border:none;border-radius:8px;font-size:14px;}"
                            "QToolButton:hover{background:rgba(216,168,73,0.10);}"
                            "QToolButton:checked{background:rgba(216,168,73,0.18);color:#f1e3c6;font-weight:700;}")
            b.clicked.connect(lambda _c, k=key: self.go(k))
            self.navgrp.addButton(b); sv.addWidget(b); self.nav[key] = b
        sv.addStretch(1)
        self.upd_badge = QLabel(""); self.upd_badge.setStyleSheet("color:#9ccf6a;font-size:12px;"); sv.addWidget(self.upd_badge)
        outer.addWidget(side)

        # ---- right: topbar + stack ----
        right = QVBoxLayout(); right.setContentsMargins(0, 0, 0, 0); right.setSpacing(0)
        top = QHBoxLayout(); top.setContentsMargins(16, 12, 16, 10)
        self.back = QToolButton(); self.back.setText("←"); self.back.clicked.connect(self.go_back)
        self.back.setStyleSheet("QToolButton{color:#e8c878;font-size:18px;border:none;padding:2px 8px;}")
        top.addWidget(self.back)
        self.search = QLineEdit(); self.search.setPlaceholderText(L("Cerca app, giochi, strumenti…", "Search apps, games, tools…"))
        self.search.setStyleSheet("QLineEdit{background:#171206;border:1px solid rgba(216,168,73,0.25);border-radius:10px;padding:8px 12px;color:#f1e3c6;font-size:14px;}")
        self.search.returnPressed.connect(self.do_search)
        top.addWidget(self.search, 1)
        self.title = QLabel(""); self.title.setStyleSheet("color:#e8c878;font-weight:700;font-size:15px;"); top.addWidget(self.title)
        right.addLayout(top)
        self.stack = QStackedWidget(); right.addWidget(self.stack, 1)
        rw = QWidget(); rw.setLayout(right); rw.setStyleSheet("background:#0b0905;")
        outer.addWidget(rw, 1)

        # panes
        self.p_loading = self._loading_pane()
        self.p_scroll = QScrollArea(); self.p_scroll.setWidgetResizable(True); self.p_scroll.setFrameShape(QFrame.Shape.NoFrame)
        self.p_host = QWidget(); self.p_lay = QVBoxLayout(self.p_host); self.p_lay.setContentsMargins(16, 6, 16, 16); self.p_lay.setSpacing(8)
        self.p_scroll.setWidget(self.p_host)
        self.p_detail = QScrollArea(); self.p_detail.setWidgetResizable(True); self.p_detail.setFrameShape(QFrame.Shape.NoFrame)
        for w in (self.p_loading, self.p_scroll, self.p_detail):
            self.stack.addWidget(w)

        self._hist = []
        self.statusBar()
        self.stack.setCurrentWidget(self.p_loading)
        self.loader = Loader(); self.loader.msg.connect(self.statusBar().showMessage)
        self.loader.done.connect(self.on_loaded); self.loader.start()

    def _loading_pane(self):
        w = QWidget(); v = QVBoxLayout(w); v.addStretch(1)
        l = QLabel(L("Carico il catalogo software…", "Loading the software catalogue…"))
        l.setAlignment(Qt.AlignmentFlag.AlignCenter); l.setStyleSheet("color:#b9a07a;font-size:16px;")
        bar = QProgressBar(); bar.setRange(0, 0); bar.setFixedWidth(280); bar.setTextVisible(False)
        v.addWidget(l); hb = QHBoxLayout(); hb.addStretch(1); hb.addWidget(bar); hb.addStretch(1); v.addLayout(hb)
        v.addStretch(1); return w

    def on_loaded(self, cat):
        self.cat = cat
        self.statusBar().clearMessage()
        self.refresh_updates_badge()
        self.go("home")
        view = os.environ.get("SFX_HUB_VIEW")  # test hook: home|cats|installed|updates|sources|cat:<Key>
        if view:
            if view.startswith("cat:"):
                self.show_category(view[4:])
            else:
                self.go(view)

    # ---------- navigation ----------
    def go(self, key, push=True):
        if push and (not self._hist or self._hist[-1] != (key,)):
            self._hist.append((key,))
        for k, b in self.nav.items():
            b.setChecked(k == key)
        if key == "home": self.show_home()
        elif key == "cats": self.show_categories()
        elif key == "installed": self.show_list([a for a in self.cat.apps.values() if a.installed],
                                                 L("Installati", "Installed"))
        elif key == "updates": self.show_updates()
        elif key == "sources": self.show_sources()

    def go_back(self):
        if len(self._hist) > 1:
            self._hist.pop()
            item = self._hist[-1]
            if item[0] == "detail": self.open_app(item[1], push=False)
            elif item[0] == "cat": self.show_category(item[1], push=False)
            elif item[0] == "search": self.show_list(item[1], item[2], push=False)
            else: self.go(item[0], push=False)

    def _clear_host(self):
        while self.p_lay.count():
            it = self.p_lay.takeAt(0); w = it.widget()
            if w is not None: w.setParent(None)

    def _grid_of(self, apps, limit=None):
        if limit: apps = apps[:limit]
        for a in apps:
            self.p_lay.addWidget(AppCard(a, self.open_app))
        if not apps:
            e = QLabel(L("Nessun risultato.", "No results.")); e.setStyleSheet("color:#b9a07a;"); self.p_lay.addWidget(e)
        self.p_lay.addStretch(1)

    # ---------- panes ----------
    def show_home(self):
        self.title.setText(""); self._clear_host()
        h = QLabel(L("In evidenza · SkillFishOS", "Featured · SkillFishOS")); h.setStyleSheet("color:#e8c878;font-size:16px;font-weight:700;")
        self.p_lay.addWidget(h)
        ours = [a for a in self.cat.apps.values() if a.backend == "apt" and a.origin == AETHERIUM]
        for a in sorted(ours, key=lambda a: a.name.lower()):
            self.p_lay.addWidget(AppCard(a, self.open_app))
        cl = QLabel(L("Sfoglia per categoria", "Browse by category")); cl.setStyleSheet("color:#e8c878;font-size:16px;font-weight:700;margin-top:8px;")
        self.p_lay.addWidget(cl)
        grid = QGridLayout(); host = QWidget(); host.setLayout(grid)
        for i, (key, name, emoji, _m) in enumerate(CATEGORIES):
            b = QPushButton("%s  %s" % (emoji, name)); b.setMinimumHeight(54)
            b.setStyleSheet("QPushButton{background:rgba(255,255,255,0.03);border:1px solid rgba(216,168,73,0.18);border-radius:12px;color:#f1e3c6;font-size:14px;text-align:left;padding-left:14px;}"
                            "QPushButton:hover{background:rgba(216,168,73,0.10);}")
            b.clicked.connect(lambda _c, k=key: self.show_category(k))
            grid.addWidget(b, i // 3, i % 3)
        self.p_lay.addWidget(host)
        self.p_lay.addStretch(1)
        self.stack.setCurrentWidget(self.p_scroll)

    def show_categories(self):
        self.title.setText(""); self._clear_host()
        for key, name, emoji, _m in CATEGORIES:
            n = len(self.cat.by_cat.get(key, []))
            b = QPushButton("%s   %s    ·  %d" % (emoji, name, n)); b.setMinimumHeight(50)
            b.setStyleSheet("QPushButton{background:rgba(255,255,255,0.03);border:1px solid rgba(216,168,73,0.18);border-radius:12px;color:#f1e3c6;font-size:15px;text-align:left;padding-left:14px;}"
                            "QPushButton:hover{background:rgba(216,168,73,0.10);}")
            b.clicked.connect(lambda _c, k=key: self.show_category(k))
            self.p_lay.addWidget(b)
        self.p_lay.addStretch(1)
        self.stack.setCurrentWidget(self.p_scroll)

    def show_category(self, key, push=True):
        if push: self._hist.append(("cat", key))
        name = dict((c[0], c[1]) for c in CATEGORIES).get(key, key)
        self.title.setText(name); self._clear_host()
        self._grid_of(self.cat.by_cat.get(key, []))
        self.stack.setCurrentWidget(self.p_scroll)

    def show_list(self, apps, title, push=True):
        if push: self._hist.append(("list", apps, title) if title != "search" else ("search", apps, title))
        self.title.setText(title if isinstance(title, str) else ""); self._clear_host()
        self._grid_of(apps)
        self.stack.setCurrentWidget(self.p_scroll)

    def do_search(self):
        q = self.search.text().strip()
        if len(q) < 2 or self.cat is None: return
        self.title.setText(L("Ricerca: ", "Search: ") + q); self._clear_host()
        self.p_lay.addWidget(QLabel(L("Cerco…", "Searching…")))
        self.stack.setCurrentWidget(self.p_scroll)
        self._st = SearchThread(self.cat, q)
        self._st.done.connect(lambda res, qq=q: self._search_done(res, qq)); self._st.start()

    def _search_done(self, res, q):
        self._hist.append(("search", res, L("Ricerca: ", "Search: ") + q))
        self._clear_host(); self._grid_of(res)

    # ---------- app detail ----------
    def open_app(self, app, push=True):
        if push: self._hist.append(("detail", app))
        self.title.setText(app.name)
        w = QWidget(); v = QVBoxLayout(w); v.setContentsMargins(20, 14, 20, 18); v.setSpacing(12)
        head = QHBoxLayout(); ic = QLabel(); ic.setPixmap(pixmap_for(app, 84)); ic.setFixedWidth(96); head.addWidget(ic)
        tcol = QVBoxLayout(); tcol.setSpacing(2)
        nm = QLabel(app.name); nm.setStyleSheet("font-size:24px;font-weight:800;color:#e8c878;"); tcol.addWidget(nm)
        sm = QLabel(app.summary or ""); sm.setStyleSheet("color:#b9a07a;font-size:14px;"); sm.setWordWrap(True); tcol.addWidget(sm)
        meta = QHBoxLayout(); src = SRC_LABEL.get(app.backend, app.backend)
        if app.backend == "apt" and app.origin == AETHERIUM: src = "SkillFishOS"
        meta.addWidget(badge(src))
        if app.ver: meta.addWidget(badge("v" + app.ver))
        if app.installed: meta.addWidget(badge("✓ " + L("installato", "installed"), "#9ccf6a"))
        meta.addStretch(1); tcol.addLayout(meta)
        head.addLayout(tcol, 1)
        btncol = QVBoxLayout()
        if app.installed:
            rm = QPushButton(L("Rimuovi", "Remove")); rm.clicked.connect(lambda: self.do_op(app, "remove"))
            rm.setStyleSheet("QPushButton{background:#3a221c;color:#e0b0a0;border-radius:10px;padding:9px 22px;font-weight:700;}QPushButton:hover{color:#ff9a7a;}")
            btncol.addWidget(rm)
        else:
            ins = QPushButton(L("Installa", "Install")); ins.clicked.connect(lambda: self.do_op(app, "install"))
            ins.setStyleSheet("QPushButton{background:#9ccf6a;color:#10240a;border-radius:10px;padding:9px 26px;font-weight:800;}QPushButton:hover{background:#aee07c;}")
            btncol.addWidget(ins)
        btncol.addStretch(1); head.addLayout(btncol)
        v.addLayout(head)

        # screenshots
        if app.screens:
            sc = QScrollArea(); sc.setFixedHeight(200); sc.setWidgetResizable(True); sc.setFrameShape(QFrame.Shape.NoFrame)
            sh = QWidget(); shl = QHBoxLayout(sh); shl.setSpacing(10)
            for url in app.screens:
                lab = QLabel(); pm = QPixmap()
                if url.startswith("http"):
                    pass  # remote screenshots loaded lazily would need network; show local only for now
                elif os.path.exists(url):
                    pm = QPixmap(url)
                if not pm.isNull():
                    lab.setPixmap(pm.scaledToHeight(180, Qt.TransformationMode.SmoothTransformation))
                    shl.addWidget(lab)
            shl.addStretch(1); sc.setWidget(sh)
            if shl.count() > 1: v.addWidget(sc)

        # description
        desc = QLabel(); desc.setTextFormat(Qt.TextFormat.RichText); desc.setWordWrap(True)
        desc.setStyleSheet("color:#d9c8a8;font-size:13px;")
        d = app.description or app.summary or ""
        desc.setText(d if d.strip().startswith("<") else "<p>%s</p>" % html.escape(d))
        v.addWidget(desc)
        v.addStretch(1)
        self.p_detail.setWidget(w)
        self.stack.setCurrentWidget(self.p_detail)

    # ---------- operations ----------
    def do_op(self, app, action):
        if action == "install":
            argv = self._install_cmd(app)
            verb = L("Installazione", "Installing")
        else:
            argv = self._remove_cmd(app)
            verb = L("Rimozione", "Removing")
        self._run_op(argv, "%s %s…" % (verb, app.name), app)

    def _install_cmd(self, app):
        if app.backend == "apt": return ["pkexec", HELPER, "apt-install", app.pkgid]
        if app.backend == "flatpak": return ["flatpak", "install", "-y", "--noninteractive", "flathub", app.pkgid]
        if app.backend == "snap": return ["pkexec", "snap", "install", app.pkgid]
    def _remove_cmd(self, app):
        if app.backend == "apt": return ["pkexec", HELPER, "apt-remove", app.pkgid]
        if app.backend == "flatpak": return ["flatpak", "uninstall", "-y", "--noninteractive", app.pkgid]
        if app.backend == "snap": return ["pkexec", "snap", "remove", app.pkgid]

    def _run_op(self, argv, title, app=None):
        dlg = QDialog(self); dlg.setWindowTitle("SkillFishOS Hub"); dlg.resize(640, 420)
        v = QVBoxLayout(dlg); v.addWidget(QLabel(title))
        log = QPlainTextEdit(); log.setReadOnly(True); v.addWidget(log)
        bar = QProgressBar(); bar.setRange(0, 0); v.addWidget(bar)
        closeb = QPushButton(L("Chiudi", "Close")); closeb.setEnabled(False); closeb.clicked.connect(dlg.accept)
        v.addWidget(closeb)
        self._op = Op(argv)
        self._op.line.connect(log.appendPlainText)
        def fin(rc):
            bar.setRange(0, 1); bar.setValue(1); closeb.setEnabled(True)
            log.appendPlainText("\n" + (L("✓ Completato.", "✓ Done.") if rc == 0 else L("! Operazione fallita (rc=%d)" % rc, "! Operation failed (rc=%d)" % rc)))
            self.reload_catalog()
        self._op.done.connect(fin); self._op.start()
        dlg.exec()

    # ---------- updates ----------
    def show_updates(self):
        self.title.setText(L("Aggiornamenti", "Updates")); self._clear_host()
        self.p_lay.addWidget(QLabel(L("Controllo aggiornamenti…", "Checking for updates…")))
        self.stack.setCurrentWidget(self.p_scroll)
        self._ut = UpdatesThread(self.cat); self._ut.done.connect(self._updates_done); self._ut.start()

    def _updates_done(self, ups):
        self._clear_host()
        top = QHBoxLayout()
        n = len(ups)
        t = QLabel(L("%d aggiornamenti disponibili" % n if n else "Tutto aggiornato ✓",
                     "%d updates available" % n if n else "Everything is up to date ✓"))
        t.setStyleSheet("color:#e8c878;font-size:16px;font-weight:700;"); top.addWidget(t); top.addStretch(1)
        if n:
            allb = QPushButton(L("Aggiorna tutto", "Update all")); allb.clicked.connect(self.update_all)
            allb.setStyleSheet("QPushButton{background:#9ccf6a;color:#10240a;border-radius:10px;padding:8px 20px;font-weight:800;}")
            top.addWidget(allb)
        hw = QWidget(); hw.setLayout(top); self.p_lay.addWidget(hw)
        for backend, name, oldv, newv in ups:
            row = QFrame(); rl = QHBoxLayout(row); rl.setContentsMargins(12, 8, 12, 8)
            row.setStyleSheet("QFrame{background:rgba(255,255,255,0.03);border:1px solid rgba(216,168,73,0.14);border-radius:10px;}")
            nm = QLabel(name); nm.setStyleSheet("color:#f1e3c6;font-weight:600;"); rl.addWidget(nm)
            rl.addWidget(badge(SRC_LABEL.get(backend, backend))); rl.addStretch(1)
            if newv: rl.addWidget(QLabel("→ %s" % newv))
            self.p_lay.addWidget(row)
        self.p_lay.addStretch(1)

    def update_all(self):
        # chain apt + flatpak + snap
        cmds = []
        if have("apt-get"): cmds.append(["pkexec", HELPER, "apt-upgrade"])
        if have("flatpak"): cmds.append(["flatpak", "update", "-y", "--noninteractive"])
        if have("snap"): cmds.append(["pkexec", "snap", "refresh"])
        # run sequentially through one dialog
        self._run_chain(cmds, L("Aggiornamento di tutto il sistema…", "Updating the whole system…"))

    def _run_chain(self, cmds, title):
        dlg = QDialog(self); dlg.setWindowTitle("SkillFishOS Hub"); dlg.resize(680, 460)
        v = QVBoxLayout(dlg); v.addWidget(QLabel(title))
        log = QPlainTextEdit(); log.setReadOnly(True); v.addWidget(log)
        bar = QProgressBar(); bar.setRange(0, 0); v.addWidget(bar)
        closeb = QPushButton(L("Chiudi", "Close")); closeb.setEnabled(False); closeb.clicked.connect(dlg.accept); v.addWidget(closeb)
        self._chain = list(cmds)
        def nxt(_rc=0):
            if not self._chain:
                bar.setRange(0, 1); bar.setValue(1); closeb.setEnabled(True)
                log.appendPlainText("\n" + L("✓ Aggiornamento completato.", "✓ Update complete."))
                self.reload_catalog(); return
            argv = self._chain.pop(0)
            log.appendPlainText("\n$ " + " ".join(argv))
            self._op = Op(argv); self._op.line.connect(log.appendPlainText); self._op.done.connect(nxt); self._op.start()
        nxt(); dlg.exec()

    def refresh_updates_badge(self):
        self._ub = UpdatesThread(self.cat)
        self._ub.done.connect(lambda ups: (self.upd_badge.setText(L("⟳ %d aggiornamenti" % len(ups) if ups else "",
                                                                     "⟳ %d updates" % len(ups) if ups else "")),
                                           self.nav["updates"].setText("  ⟳   " + L("Aggiornamenti", "Updates") + (" (%d)" % len(ups) if ups else ""))))
        self._ub.start()

    def reload_catalog(self):
        self.statusBar().showMessage(L("Ricarico…", "Reloading…"))
        self.loader = Loader(); self.loader.done.connect(self._reloaded); self.loader.start()
    def _reloaded(self, cat):
        self.cat = cat; self.statusBar().clearMessage(); self.refresh_updates_badge()
        # refresh current view
        cur = self._hist[-1] if self._hist else ("home",)
        if cur[0] == "detail":
            a = self.cat.apps.get(cur[1].key, cur[1]); self.open_app(a, push=False)
        else:
            self.go(cur[0], push=False)

    # ---------- sources ----------
    def show_sources(self):
        self.title.setText(L("Sorgenti software", "Software sources")); self._clear_host()
        # APT repos
        h = QHBoxLayout(); lab = QLabel(L("Repository APT", "APT repositories")); lab.setStyleSheet("color:#e8c878;font-size:16px;font-weight:700;")
        h.addWidget(lab); h.addStretch(1)
        addb = QPushButton(L("+ Aggiungi repository", "+ Add repository")); addb.clicked.connect(self.add_repo_dialog)
        addb.setStyleSheet("QPushButton{background:rgba(216,168,73,0.18);color:#f1e3c6;border-radius:9px;padding:6px 14px;}")
        h.addWidget(addb); hw = QWidget(); hw.setLayout(h); self.p_lay.addWidget(hw)
        for name, info, enabled in self._list_apt_repos():
            row = QFrame(); rl = QHBoxLayout(row); rl.setContentsMargins(12, 8, 12, 8)
            row.setStyleSheet("QFrame{background:rgba(255,255,255,0.03);border:1px solid rgba(216,168,73,0.14);border-radius:10px;}")
            cb = QCheckBox(); cb.setChecked(enabled); cb.toggled.connect(lambda en, n=name: self.repo_enable(n, en))
            rl.addWidget(cb)
            col = QVBoxLayout(); col.setSpacing(0)
            nl = QLabel(name); nl.setStyleSheet("color:#f1e3c6;font-weight:700;")
            il = QLabel(info); il.setStyleSheet("color:#b9a07a;font-size:12px;"); il.setWordWrap(True)
            col.addWidget(nl); col.addWidget(il); rl.addLayout(col, 1)
            if name not in ("debian", "skillfishos"):
                rb = QPushButton("🗑"); rb.setFixedWidth(36); rb.clicked.connect(lambda _c, n=name: self.repo_remove(n))
                rb.setStyleSheet("QPushButton{background:transparent;color:#cf8a6a;border:none;font-size:16px;}")
                rl.addWidget(rb)
            self.p_lay.addWidget(row)
        # Flatpak remotes
        fl = QLabel(L("Remote Flatpak", "Flatpak remotes")); fl.setStyleSheet("color:#e8c878;font-size:16px;font-weight:700;margin-top:8px;")
        self.p_lay.addWidget(fl)
        for name, url in self._list_flatpak_remotes():
            row = QFrame(); rl = QHBoxLayout(row); rl.setContentsMargins(12, 8, 12, 8)
            row.setStyleSheet("QFrame{background:rgba(255,255,255,0.03);border:1px solid rgba(216,168,73,0.14);border-radius:10px;}")
            col = QVBoxLayout(); col.setSpacing(0)
            nl = QLabel(name + "   "); nl.setStyleSheet("color:#f1e3c6;font-weight:700;")
            ul = QLabel(url); ul.setStyleSheet("color:#b9a07a;font-size:12px;")
            col.addWidget(nl); col.addWidget(ul); rl.addLayout(col, 1)
            self.p_lay.addWidget(row)
        si = QLabel(L("Snap: store ufficiale (snapcraft.io) sempre attivo.",
                      "Snap: official store (snapcraft.io), always on.")); si.setStyleSheet("color:#b9a07a;margin-top:6px;")
        self.p_lay.addWidget(si)
        self.p_lay.addStretch(1)
        self.stack.setCurrentWidget(self.p_scroll)

    def _list_apt_repos(self):
        out = []
        d = "/etc/apt/sources.list.d"
        try:
            for fn in sorted(os.listdir(d)):
                if not fn.endswith(".sources"): continue
                name = fn[:-8]
                enabled = True; uris = suites = ""
                try:
                    with open(os.path.join(d, fn)) as f:
                        for line in f:
                            ls = line.strip()
                            if ls.lower().startswith("uris:"): uris = ls.split(":", 1)[1].strip()
                            elif ls.lower().startswith("suites:"): suites = ls.split(":", 1)[1].strip()
                            elif ls.lower().startswith("enabled:"): enabled = "no" not in ls.lower()
                except Exception:
                    pass  # best-effort: unreadable source file
                out.append((name, "%s  ·  %s" % (uris, suites), enabled))
        except Exception:
            pass  # best-effort
        return out

    def _list_flatpak_remotes(self):
        out = []
        if have("flatpak"):
            rc, o, _ = run(["flatpak", "remotes", "--columns=name,url"], 15)
            for ln in o.splitlines():
                f = ln.split("\t")
                if len(f) >= 1 and f[0]: out.append((f[0].strip(), f[1].strip() if len(f) > 1 else ""))
        return out

    def add_repo_dialog(self):
        d = QDialog(self); d.setWindowTitle(L("Aggiungi repository APT", "Add APT repository")); d.resize(520, 300)
        fl = QFormLayout(d)
        name = QLineEdit(); name.setPlaceholderText("es. mio-repo")
        uri = QLineEdit(); uri.setPlaceholderText("https://example.com/debian")
        suite = QLineEdit(); suite.setText("stable")
        comps = QLineEdit(); comps.setText("main")
        keyurl = QLineEdit(); keyurl.setPlaceholderText(L("URL chiave .asc (opzionale)", "key .asc URL (optional)"))
        fl.addRow(L("Nome", "Name"), name); fl.addRow("URI", uri); fl.addRow(L("Suite", "Suite"), suite)
        fl.addRow(L("Componenti", "Components"), comps); fl.addRow(L("Chiave", "Key"), keyurl)
        bb = QHBoxLayout(); ok = QPushButton(L("Aggiungi", "Add")); ca = QPushButton(L("Annulla", "Cancel"))
        ok.clicked.connect(d.accept); ca.clicked.connect(d.reject); bb.addStretch(1); bb.addWidget(ca); bb.addWidget(ok)
        fl.addRow(bb)
        if d.exec() != QDialog.DialogCode.Accepted: return
        nm = re.sub(r'[^a-zA-Z0-9_-]', '', name.text().strip())
        if not nm or not uri.text().strip(): return
        signed = ""
        if keyurl.text().strip():
            rc, o, e = run(["bash", "-c", "curl -fsSL %s" % keyurl.text().strip()], 30)
            if rc == 0 and o:
                import base64
                b64 = base64.b64encode(o.encode()).decode()
                run(["pkexec", HELPER, "key-add", nm, b64], 30)
                signed = "Signed-By: /usr/share/keyrings/%s.gpg\n" % nm
        content = ("Types: deb\nURIs: %s\nSuites: %s\nComponents: %s\n%sEnabled: yes\n"
                   % (uri.text().strip(), suite.text().strip(), comps.text().strip(), signed))
        import base64
        b64 = base64.b64encode(content.encode()).decode()
        self._run_op(["pkexec", HELPER, "repo-add", nm, b64], L("Aggiungo il repository…", "Adding the repository…"))

    def repo_remove(self, name):
        if QMessageBox.question(self, "SkillFishOS",
                L(f"Rimuovere il repository '{name}'?", f"Remove the '{name}' repository?")) == QMessageBox.StandardButton.Yes:
            self._run_op(["pkexec", HELPER, "repo-remove", name], L("Rimuovo il repository…", "Removing the repository…"))

    def repo_enable(self, name, en):
        run(["pkexec", HELPER, "repo-enable", name, "1" if en else "0"], 90)
        self.statusBar().showMessage(L("Repository aggiornato. Ricarico…", "Repository updated. Reloading…"))
        self.reload_catalog()


def main():
    app = QApplication(sys.argv)
    app.setApplicationName("SkillFishOS Hub")
    app.setDesktopFileName("os.skillfish.hub")
    app.setWindowIcon(QIcon(ICON))
    w = Hub()
    w.show(); w.raise_(); w.activateWindow()
    sys.exit(app.exec())

if __name__ == "__main__":
    main()
